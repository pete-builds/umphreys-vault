# ---------------------------------------------------------------------------
# umphreys-vault — environment variables
#
# Copy to `.env` on the host. NEVER commit `.env`.
# ---------------------------------------------------------------------------

# ---- Postgres ----
PG_DB=umphreys
PG_USER=umphreys
# Generate a long random password. Example:
#   openssl rand -base64 32
PG_PASSWORD=replace-me
# Host/port only matter inside containers; Postgres is reached via the
# `postgres` service name.
PG_HOST=postgres
PG_PORT=5432

# ---- Upstream API (All Things Umphreys) ----
# Public API: no auth, no key. Override only for testing.
ATU_BASE_URL=https://allthings.umphreys.com/api/v2
ATU_ARTIST_ID=1

# ---- ETL behavior ----
ETL_CONCURRENCY=4
# Polite throttle: there's no API key, so keep the request rate low.
ETL_THROTTLE_ATU_RPS=3
ETL_REQUEST_TIMEOUT_S=20
ETL_DRY_RUN=false

# ---- Status endpoint ----
STATUS_HOST=0.0.0.0
# 3719: 3716 is taken by mcp-youtube on nix1 (see homelab-webapps registry).
STATUS_PORT=3719

# ---- Logging ----
LOG_LEVEL=INFO
LOG_FORMAT=json
